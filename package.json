    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "emoji-picker-react": "^4.19.1",
    "livekit-client": "^2.19.2",
    "livekit-server-sdk": "^2.15.5",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pusher": "^5.3.3",
    "pusher-js": "^8.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
