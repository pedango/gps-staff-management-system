# Copy to `.env.local` and fill values.
# Prisma CLI does not load `.env.local` by default — use npm scripts (`db:generate`, `db:migrate`, etc.)
# or run: `npx dotenv -e .env.local -- prisma <command>`.

DATABASE_URL=

# Use origin only (no path). Auth.js v5 also accepts AUTH_SECRET / AUTH_URL.
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# After adding call tables: npx prisma migrate deploy

# Optional TURN (improves calls behind strict firewalls/NAT)
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

