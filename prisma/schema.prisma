generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String
  avatar           String?
  role             String            @default("admin")
  sentMessages     Message[]         @relation("Sender")
  receivedMessages Message[]         @relation("Receiver")
  hostedCalls      CallSession[]     @relation("CallHost")
  callParticipants CallParticipant[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([email])
}

model CallSession {
  id             String            @id @default(cuid())
  hostId         String
  conversationId String?
  callType       CallTypeEnum
  status         CallSessionStatus @default(ACTIVE)
  host           Admin             @relation("CallHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants   CallParticipant[]
  createdAt      DateTime          @default(now())
  endedAt        DateTime?

  @@index([status])
  @@index([hostId])
}

model CallParticipant {
  id        String      @id @default(cuid())
  sessionId String
  adminId   String
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  session   CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  admin     Admin       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([sessionId, adminId])
  @@index([sessionId])
  @@index([adminId])
}

/**
 * Server-side proof that a participant enabled end-to-end encryption for a call.
 * `verified` is true only when the participant proved possession of the exact
 * conversation E2EE key (its fingerprint matched the server-derived key).
 */
model CallEncryptionAudit {
  id              String   @id @default(cuid())
  conversationId  String
  participantId   String
  participantName String
  callType        String?
  encrypted       Boolean  @default(true)
  keyFingerprint  String
  verified        Boolean  @default(false)
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

enum CallTypeEnum {
  AUDIO
  VIDEO
}

enum CallSessionStatus {
  ACTIVE
  ENDED
}

/** Singleton row (id = "default") — regional / system preferences editable by admins. */
model SystemConfig {
  id                    String   @id @default("default")
  regionName            String   @default("Eastern North Region")
  orgName               String   @default("Ghana Police Service")
  systemTitle           String   @default("Personnel Management System")
  membersPageSize       Int      @default(20)
  enableDirectMessaging Boolean  @default(true)
  requireMemberPhoto    Boolean  @default(false)
  maintenanceMode       Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

model Member {
  id         String       @id @default(cuid())
  firstName  String
  lastName   String
  otherNames String?
  dob        DateTime
  sex        Sex
  rank       String
  contact    String
  department String
  division   String
  district   String
  station    String
  status     MemberStatus @default(ACTIVE)
  photo      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([lastName, firstName])
  @@index([district])
  @@index([division])
  @@index([station])
  @@index([status])
  @@index([contact])
}

model Message {
  id            String    @id @default(cuid())
  senderId      String
  receiverId    String
  text          String?
  fileUrl       String?
  fileType      FileType?
  fileName      String?
  voiceUrl      String?
  voiceDuration Int?
  readAt        DateTime?
  sender        Admin     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      Admin     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@index([createdAt])
}

enum Sex {
  MALE
  FEMALE
}

enum MemberStatus {
  ACTIVE
  SICK
  INJURED
  MATERNITY_LEAVE
  RETIRED
}

enum FileType {
  PDF
  IMAGE
  VOICE
}
